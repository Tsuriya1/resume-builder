# =========================
# General
# =========================

NODE_ENV=development
APP_NAME=resume-builder
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# =========================
# Frontend
# =========================

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000

# =========================
# Backend
# =========================

PORT=4000

# =========================
# Database
# =========================

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/resume_builder

# Optional separate DB fields if needed by the backend implementation
DB_HOST=localhost
DB_PORT=5432
DB_NAME=resume_builder
DB_USER=postgres
DB_PASSWORD=postgres

# =========================
# Authentication - Google OAuth
# =========================

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/auth/google/callback

# =========================
# Session / Auth
# =========================

SESSION_SECRET=change_this_to_a_long_random_secret
JWT_SECRET=change_this_if_you_use_jwt

# =========================
# AI Provider
# =========================

OPENAI_API_KEY=your_openai_api_key
AI_MODEL=gpt-5

# =========================
# Object Storage / File Storage
# =========================

STORAGE_PROVIDER=local

# local / s3-compatible examples
STORAGE_BUCKET=resume-builder
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=your_storage_access_key
STORAGE_SECRET_KEY=your_storage_secret_key
STORAGE_ENDPOINT=
STORAGE_PUBLIC_BASE_URL=

# =========================
# Export Settings
# =========================

PDF_EXPORT_ENABLED=true
DOCX_EXPORT_ENABLED=true

# =========================
# Admin
# =========================

ADMIN_EMAILS=admin@example.com

# =========================
# Logging
# =========================

LOG_LEVEL=debug